# Application Settings
APP_NAME="School Payment System"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG=True
API_PREFIX="/api/v1"

# Server Configuration
HOST="0.0.0.0"
PORT=8000
ALLOWED_HOSTS="localhost,127.0.0.1,scolapp.com,api.scolapp.com"

# Database Configuration
DATABASE_URL="mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/school_payments"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Security
SECRET_KEY="GENERATE_A_STRONG_SECRET_KEY_HERE"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# D-Money Payment Gateway - Credentials
DMONEY_APP_ID="your_app_id"
DMONEY_APP_KEY="your_app_key_uuid"
DMONEY_APP_SECRET="your_app_secret"
DMONEY_SHORT_CODE="your_merchant_short_code"
DMONEY_PUBLIC_KEY="base64_encoded_dmoney_public_key"
DMONEY_PRIVATE_KEY="base64_encoded_your_private_key"

# D-Money API Endpoints (switch to production URLs when going live)
DMONEY_TOKEN_URL="https://pgtest.d-money.dj:38443/apiaccess/payment/gateway/payment/v1/token"
DMONEY_PREORDER_URL="https://pgtest.d-money.dj:38443/apiaccess/payment/gateway/payment/v1/merchant/preOrder"
DMONEY_QUERY_ORDER_URL="https://pgtest.d-money.dj:38443/apiaccess/payment/gateway/payment/v1/merchant/queryOrder"

# Payment Configuration
PAYMENT_CURRENCY="DJF"
PAYMENT_CALLBACK_URL="https://api.scolapp.com/api/v1/webhooks/dmoney"
PAYMENT_SUCCESS_URL="https://scolapp.com/payment/success"
PAYMENT_CANCEL_URL="https://scolapp.com/payment/cancel"

# Scolapp Integration
SCOLAPP_DOMAIN="https://scolapp.com"
SCOLAPP_API_KEY="scolapp_system_api_key"

# SMS Notifications (optional)
SMS_PROVIDER="twilio"
SMS_API_KEY=""
SMS_SENDER_NUMBER=""

# Email Configuration (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@scolapp.com"
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@scolapp.com"
SMTP_FROM_NAME="Scolapp Payment System"

# Logging
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE="logs/app.log"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS Settings
CORS_ORIGINS="https://scolapp.com,http://localhost:3000"
CORS_ALLOW_CREDENTIALS=True
